{
  "compilerOptions": {
    "target": "ES2022",
    "module": "ES2022",
    "moduleResolution": "bundler",
    "strict": true,
    "noEmit": true,
    "skipLibCheck": true,
    "lib": ["ES2022", "DOM", "DOM.Iterable", "WebWorker"],
    "types": ["@cloudflare/workers-types"]
  },
  "include": [
    "src/functions/**/*.ts",
    "scripts/**/*.ts"
  ]
}
